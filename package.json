{
  "name": "@obsku/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/apps/*",
    "packages/adapters/*",
    "packages/providers/*",
    "packages/tools/*"
  ],
  "scripts": {
    "build": "bun run --filter '@obsku/framework' build && bun run --filter '@obsku/tool-code-interpreter' build && bun run --filter '*' build",
    "test": "bun test $(find packages -name '*.test.ts' ! -path '*code-interpreter-wasm*' ! -path '*code-interpreter-agentcore*') && bun test packages/tools/code-interpreter-agentcore",
    "test:wasm": "bun test packages/tools/code-interpreter-wasm",
    "typecheck": "tsgo --build --emitDeclarationOnly",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "bunx biome format --write .",
    "check": "bunx biome ci --linter-enabled=false --assist-enabled=false .",
    "verify:hygiene": "bun run scripts/verify-hygiene.ts",
    "verify:publish": "bun run scripts/verify-publish.ts",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@changesets/cli": "^2.30.0",
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@types/bun": "^1.3.8",
    "@typescript/native-preview": "^7.0.0-dev.20260219.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "oxlint": "^1.48.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.1.0"
  }
}
