{
  "name": "@obsku/adapter-agent-server",
  "version": "0.1.0",
  "description": "A2A/AgentCore HTTP server adapter for @obsku/framework",
  "keywords": [
    "obsku",
    "agent",
    "ai",
    "llm",
    "typescript",
    "adapter",
    "server",
    "a2a",
    "agentcore"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/adapters/agent-server"
  },
  "author": "Obsku Team <team@obsku.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepack": "bun run ../../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/framework": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/obskuai/obsku/tree/main/packages/adapters/agent-server",
  "bugs": {
    "url": "https://github.com/obskuai/obsku/issues"
  }
}
