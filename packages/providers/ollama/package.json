{
  "name": "@obsku/provider-ollama",
  "version": "0.2.2",
  "description": "Ollama embedding provider for @obsku/framework",
  "keywords": [
    "obsku",
    "agent",
    "ai",
    "llm",
    "typescript",
    "provider",
    "ollama",
    "embedding"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/providers/ollama"
  },
  "author": "Obsku Team <team@obsku.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepack": "bun run ../../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/framework": "workspace:*",
    "ollama": "^0.5.12"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/obskuai/obsku/tree/main/packages/providers/ollama",
  "bugs": {
    "url": "https://github.com/obskuai/obsku/issues"
  }
}
