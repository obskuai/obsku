{
  "name": "@obsku/provider-bedrock",
  "version": "0.1.0",
  "description": "AWS Bedrock provider for @obsku/framework",
  "keywords": [
    "obsku",
    "agent",
    "ai",
    "llm",
    "typescript",
    "provider",
    "bedrock",
    "aws"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/providers/bedrock"
  },
  "author": "obsku",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepack": "bun run ../../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/framework": "workspace:*",
    "@aws-sdk/client-bedrock-runtime": "^3.981.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
