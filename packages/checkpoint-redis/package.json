{
  "name": "@obsku/checkpoint-redis",
  "version": "0.1.0",
  "description": "Redis checkpoint storage backend for @obsku/framework",
  "keywords": [
    "obsku",
    "agent",
    "framework",
    "checkpoint",
    "storage",
    "redis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/checkpoint-redis"
  },
  "author": "Obsku Team <team@obsku.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepack": "bun run ../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/framework": "workspace:*",
    "zod": "^4.3.6",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://github.com/obskuai/obsku/tree/main/packages/checkpoint-redis",
  "bugs": {
    "url": "https://github.com/obskuai/obsku/issues"
  }
}
