{
  "name": "@obsku/cli",
  "version": "0.2.2",
  "description": "CLI for @obsku/framework - scaffold and run agents",
  "keywords": [
    "obsku",
    "cli",
    "agent",
    "ai",
    "llm",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/cli"
  },
  "author": "Obsku Team <team@obsku.dev>",
  "type": "module",
  "bin": {
    "obsku": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run ../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/framework": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/obskuai/obsku/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/obskuai/obsku/issues"
  }
}
