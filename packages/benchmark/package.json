{
  "name": "@obsku/benchmark",
  "version": "0.1.1",
  "description": "Internal benchmark platform for @obsku/framework",
  "private": true,
  "keywords": [
    "obsku",
    "benchmark",
    "testing",
    "performance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obskuai/obsku.git",
    "directory": "packages/benchmark"
  },
  "author": "Obsku Team <team@obsku.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && rm -f tsconfig.tsbuildinfo && bunx tsgo --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepack": "bun run ../../scripts/resolve-workspace-deps.ts",
    "postpack": "bun run ../../scripts/restore-workspace-deps.ts"
  },
  "dependencies": {
    "@obsku/checkpoint-sqlite": "workspace:*",
    "effect": "^3.0.0",
    "@obsku/framework": "workspace:*",
    "@obsku/provider-bedrock": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "src/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
